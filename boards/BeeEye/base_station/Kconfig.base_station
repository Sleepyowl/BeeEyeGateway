config BOARD_BASE_STATION
	select SOC_ESP32_C6_WROOM_1U_N8
	select SOC_ESP32C6_HPCORE if BOARD_BASE_STATION_ESP32C6_HPCORE
	select SOC_ESP32C6_LPCORE if BOARD_BASE_STATION_ESP32C6_LPCORE
